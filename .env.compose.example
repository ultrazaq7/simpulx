NODE_ENV=production
PORT=3002
API_PREFIX=api/v1
SIMPULX_ENV_FILE=.env.compose.example

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=simpulx
DB_PASSWORD=change-me
DB_DATABASE=simpulx_crm

REDIS_HOST=redis
REDIS_PORT=6379

CORS_ORIGINS=https://app.simpulx.com,https://simpulx.com,https://www.simpulx.com
APP_URL=https://app.simpulx.com
APP_BASE_URL=https://simpulx.com

UPLOAD_DIR=/var/lib/simpulx/uploads
UPLOADS_DIR=/var/lib/simpulx/uploads
UPLOADS_VOLUME=simpulx_uploads
POSTGRES_VOLUME=simpulx_postgres_data
REDIS_VOLUME=simpulx_redis_data
SIMPULX_CONFIG_DIR=./deploy/local-secrets

API_HOST_PORT=3002
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
NGINX_HTTP_PORT=8080

FIREBASE_SERVICE_ACCOUNT=/etc/simpulx/firebase-service-account.json
GCP_KEY_FILE=/etc/simpulx/gcp-key.json

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change-me
SMTP_PASS=change-me
SMTP_FROM=Simpulx <noreply@simpulx.com>

FACEBOOK_APP_ID=change-me
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_APP_SECRET=change-me
META_WEBHOOK_VERIFY_TOKEN=change-me
MAX_FILE_SIZE=10485760
TZ=Asia/Jakarta
