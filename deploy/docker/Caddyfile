{
	admin off
}

# ── Main web app ──
# Cloudflare terminates client TLS at the edge (proxied/orange); CF -> origin
# uses HTTPS with the Cloudflare Origin Certificate below (SSL mode: Full strict).
app.simpulx.com {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

	# Backend API + auth + webhooks + web-api leads + media -> gateway
	@backend path /api/* /auth/* /webhook/* /v1/* /simpulx-media/*
	handle @backend {
		reverse_proxy gateway:8080
	}

	# WebSocket (realtime) -> realtime service
	handle /ws* {
		reverse_proxy realtime:8082
	}

	# Signup lives on the APEX only. The route must remain in the Next app
	# because simpulx.com proxies to it, but on the app host it does not exist:
	# a plain 404, not a redirect, per the explicit decision to remove
	# app.simpulx.com/register entirely.
	handle /register* {
		respond "not found" 404
	}
	handle /onboarding.html {
		respond "not found" 404
	}

	# Everything else -> Next.js web app
	handle {
		reverse_proxy web:3000
	}
}

# ── Landing (static) + the self-serve register flow on the APEX ──
# The marketing site is static files, but /register is the Next app: the signup
# lives on simpulx.com (where ads and the landing point), while the product
# stays on app.simpulx.com. The app paths are proxied narrowly -- the page, its
# build assets, the logo, the deck, and the PUBLIC api only -- so the apex can
# never reach authenticated app surface by accident.
simpulx.com {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

	@publicApi path /api/public/*
	handle @publicApi {
		reverse_proxy gateway:8080
	}

	@appPages path /register /register/* /_next/* /simpulx_logo.png /onboarding.html
	handle @appPages {
		reverse_proxy web:3000
	}

	# Anyone landing on /login on the apex meant the app.
	redir /login https://app.simpulx.com/login permanent

	handle {
		root * /srv/landing
		file_server
		try_files {path} {path}.html /index.html
	}
}

# www -> apex
www.simpulx.com {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	redir https://simpulx.com{uri} permanent
}
