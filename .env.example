# ── Database ────────────────────────────────────────────────
POSTGRES_USER=simpulx
POSTGRES_PASSWORD=simpulx_secret
POSTGRES_DB=simpulx_v2
DATABASE_URL=postgres://simpulx:simpulx_secret@postgres:5432/simpulx_v2?sslmode=disable

# ── Redis / NATS / MinIO ────────────────────────────────────
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=simpulx
S3_SECRET_KEY=simpulx_secret
S3_BUCKET=simpulx-media

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=dev_change_me_in_prod
JWT_ACCESS_TTL=3600           # 1h access token (silently auto-refreshed via /auth/refresh)
REFRESH_TTL=2592000           # 30d refresh token (rotating + revocable, DB-backed)

# ── Password reset / email ──────────────────────────────────
# Base URL of the web app; reset links point here (/reset-password?token=...).
APP_BASE_URL=http://localhost:3000
# SMTP for sending reset emails. Leave SMTP_HOST empty in dev: the reset link is
# logged by the gateway instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Simpulx

# ── Meta / WhatsApp ─────────────────────────────────────────
META_VERIFY_TOKEN=dev_verify_token
META_APP_SECRET=
# WhatsApp Embedded Signup (Channels > Create Channel > Login with Facebook).
# META_APP_ID + META_APP_SECRET are used server-side to exchange the signup code,
# subscribe the app to the WABA and register the number. META_CONFIG_ID is the
# Embedded Signup configuration id (also exposed to the web app, see web/.env).
META_APP_ID=
META_CONFIG_ID=
# Public base URL of THIS gateway, used to register the Viber inbound webhook.
# Must be a public https URL in production; localhost is not reachable by Viber.
PUBLIC_API_URL=http://localhost:8080
# Set WA_MOCK=true untuk dev (outbound tidak benar-benar dikirim ke Meta)
WA_MOCK=true
WA_GRAPH_BASE=https://graph.facebook.com/v21.0

# ── AI layer ────────────────────────────────────────────────
# LLM_PROVIDER: anthropic | mock   (mock = fallback offline)
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# EMBED_PROVIDER: local | openai   (local = hashing deterministik, offline)
EMBED_PROVIDER=local
EMBED_DIM=1536
OPENAI_API_KEY=
