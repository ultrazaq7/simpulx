<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The Runner target signs MANUALLY against "SimpulX Distribution Profile"
	     (see project.pbxproj). Without this file `flutter build ipa` exports with
	     automatic signing, which asks Apple for a fresh profile instead of using
	     the installed one, and fails with "requires a provisioning profile with
	     the Push Notifications feature" even though the installed profile carries
	     aps-environment=production. -->
	<key>method</key>
	<string>app-store-connect</string>
	<key>teamID</key>
	<string>VC83XAQ3UM</string>
	<key>signingStyle</key>
	<string>manual</string>
	<key>signingCertificate</key>
	<string>Apple Distribution</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>com.simpulx.app</key>
		<string>SimpulX Distribution Profile</string>
	</dict>
	<key>uploadSymbols</key>
	<true/>
	<key>destination</key>
	<string>export</string>
</dict>
</plist>
