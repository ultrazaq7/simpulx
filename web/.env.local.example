# URL backend (gateway) & realtime. Default cocok untuk dev compose.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8082

# WhatsApp Embedded Signup (Channels > Create Channel > Login with Facebook).
# Public App ID + Embedded Signup configuration id. Leave blank to hide the
# Facebook button (the Direct Cloud API path still works without these).
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
# Display-only: shown in the Direct Cloud API path so you can configure Meta's
# webhook. Should equal META_VERIFY_TOKEN on the gateway.
NEXT_PUBLIC_META_VERIFY_TOKEN=
